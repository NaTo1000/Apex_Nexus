{
  "name": "@apex-nexus/api",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --sourcemap --clean",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@apex-nexus/shared": "workspace:*",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.0.0",
    "dotenv": "^16.6.1",
    "fastify": "^4.29.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
